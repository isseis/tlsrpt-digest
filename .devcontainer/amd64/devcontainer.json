{
    "name": "x86_64 Linux Development",
    "dockerComposeFile": [
        "../docker-compose.base.yml",
        "docker-compose.yml"
    ],
    "service": "dev-env",
    "workspaceFolder": "/workspaces/ubuntu",
    "remoteUser": "devuser",
    "postCreateCommand": "cd /workspaces/ubuntu && pre-commit install",
    "remoteEnv": {
        "IMAP_TEST_HOST": "greenmail",
        "IMAP_TEST_PORT": "3143",
        "IMAP_TEST_USER": "imap-test@example.com",
        "IMAP_TEST_PASS": "imap-test@example.com",
        "IMAP_TEST_MAILBOX": "INBOX",
        "IMAP_TEST_SMTP_HOST": "greenmail",
        "IMAP_TEST_SMTP_PORT": "3025"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                }
            },
            "extensions": [
                "golang.Go",
                "ms-vscode.cpptools"
            ]
        }
    },
    "mounts": [
        "source=${localEnv:HOME}/.config/gh,target=${containerUserHome}/.config/gh,type=bind,consistency=cached"
    ]
}